{
  "name": "discount-hunt",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "bun run src/server.ts",
    "scrape": "bun run src/scraping/scraper-runner.ts",
    "test": "bun test",
    "test:acceptance": "bun test tests/acceptance",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint:arch": "depcruise src --config .dependency-cruiser.cjs",
    "build": "bun build ./src/server.ts ./src/scraping/scraper-runner.ts --target=bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "hook:push": "bun run typecheck && bun run build && bun test",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/openai-compatible": "^3.0.11",
    "ai": "^7.0.29",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.44.2",
    "htmx.org": "^2.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "dependency-cruiser": "^16.10.2",
    "drizzle-kit": "^0.31.1",
    "fast-check": "^3.23.2",
    "typescript": "^5.9.3"
  }
}
