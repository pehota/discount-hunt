# LLM provider switch — pick ONE. Unset = LLM off (rules-only, no V-Markt).
# LLM_PROVIDER=claude-cli   # local `claude` CLI (dev). Uses your local login; no API key.
# CLAUDE_CLI_MODEL=         # optional model id; omit to use the CLI default.
#
# LLM_PROVIDER=openrouter   # OpenRouter (prod). Both vars below are required.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
